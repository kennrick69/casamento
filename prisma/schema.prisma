generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  emailVerified DateTime?
  name         String?   // mantido nullable para compatibilidade com PrismaAdapter do Auth.js
  image        String?
  passwordHash String?   // null = conta criada por magic link (legacy)
  firstName    String    @default("")
  lastName     String    @default("")
  phone        String?
  marketingOptIn Boolean @default(false)

  // Controle de fluxo pós-cadastro
  profileCompleted    Boolean @default(false) // false para usuários migrados (pede completar perfil no próximo login)
  onboardingCompleted Boolean @default(false) // true para usuários migrados (já usam a plataforma)

  // LGPD
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyAcceptedAt DateTime?
  privacyVersion    String?
  acceptanceIp      String?

  // Audit
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLoginAt        DateTime?
  passwordChangedAt  DateTime?

  organizerOf    EventOrganizer[]
  accounts       Account[]
  sessions       Session[]
  passwordResets PasswordReset[]
  authLogs       AuthLog[]
  qaTestRuns     QATestRun[]
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model RateLimitAttempt {
  id        String   @id @default(cuid())
  key       String
  ip        String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([ip, createdAt])
}

model AuthLog {
  id        String     @id @default(cuid())
  userId    String?
  email     String?
  action    AuthAction
  ip        String
  userAgent String?
  metadata  Json?
  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([action, createdAt])
}

enum AuthAction {
  SIGNUP_STARTED
  SIGNUP_COMPLETED
  EMAIL_VERIFIED
  EMAIL_SEND_FAILED
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED
  EMAIL_CHANGED
  LOGOUT
  RATE_LIMITED
  CAPTCHA_FAILED
  HONEYPOT_TRIGGERED
  BACKUP_CREATED
  BACKUP_FAILED
  ACCOUNT_DELETED
  SHARE_LINK
  PAYMENT_WEBHOOK
}

// --- Auth.js v5 tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domínio ---

model Event {
  id                    String         @id @default(cuid())
  slug                  String         @unique
  title                 String
  coupleNames           String
  coupleLabel           String         @default("os noivos")
  ceremonyDate          DateTime
  timezone              String         @default("America/Sao_Paulo")
  ceremonyLocation      String?
  ceremonyAddress       String?
  receptionLocation     String?
  receptionAddress      String?
  mapsLink              String?
  dresscode             String?
  paletteColors         Json?
  description           String?        @db.Text
  coverImageKey         String?
  themeId               String
  status                EventStatus    @default(DRAFT)
  features              Json
  donationMode          DonationMode   @default(TRUST)
  pixKey                String?
  mpPublicKey           String?
  mpAccessToken         String?
  mpEnabled             Boolean        @default(false)
  mpWebhookSecret       String?
  guestApprovalRequired Boolean        @default(false)
  contentModerationMode ModerationMode @default(REACTIVE)
  publicTokenK          String
  prizeDescription      String?
  showPrize             Boolean        @default(true)
  rsvpEarlyDeadline     DateTime?
  pointsPerCurrencyUnit Float          @default(0.1)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  archivedAt            DateTime?
  archivalWarningAt     DateTime?
  customization         Json?

  theme               Theme                @relation(fields: [themeId], references: [id])
  organizers          EventOrganizer[]
  seatingTables       SeatingTable[]
  liveEvents          LiveEvent[]
  guests              Guest[]
  locations           EventLocation[]
  journeyItems        JourneyItem[]
  gifts               Gift[]
  photos              Photo[]
  galleryPhotos       GalleryPhoto[]
  chatMessages        ChatMessage[]
  playlistSuggestions PlaylistSuggestion[]
  coupleMessages      CoupleMessage[]
  missions            Mission[]
  pointEvents         PointEvent[]
  donations           Donation[]
  checkinCodes        CheckinCode[]
  checkins            Checkin[]
  reports             Report[]
  weddingParty        WeddingPartyMember[]
  storyItems          CoupleStoryItem[]
  venue3d             Venue3D?
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DonationMode {
  TRUST
  PIX_PROOF
  GATEWAY
  MERCADO_PAGO
}

enum ModerationMode {
  REACTIVE
  PREVENTIVE
}

enum LocationType {
  CEREMONY
  RECEPTION
  TEA_PARTY
  BACHELOR_PARTY
  BRUNCH
  REHEARSAL
  OTHER
}

model EventOrganizer {
  eventId         String
  userId          String
  role            OrganizerRole
  digestFrequency DigestFrequency @default(NONE)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
}

enum OrganizerRole {
  OWNER
  EDITOR
}

enum DigestFrequency {
  NONE
  DAILY
  WEEKLY
}

model Theme {
  id     String @id @default(cuid())
  key    String @unique
  name   String
  tokens Json

  events Event[]
}

model Guest {
  id                  String     @id @default(cuid())
  eventId             String
  name                String
  email               String
  phone               String?
  plusOnes            Int        @default(0)
  dietaryRestrictions String?
  message             String?    @db.Text
  rsvpStatus          RsvpStatus @default(PENDING)
  approved            Boolean    @default(true)
  sessionToken        String     @unique
  inviteToken         String?    @unique
  consentTerms        Boolean    @default(false)
  consentPhotoMural   Boolean    @default(false)
  consentTimestamp    DateTime?
  banned              Boolean    @default(false)
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // M5.5 — Quem é quem
  profileBio          String?
  profileRelationship String?
  profileImageKey     String?
  profilePublic       Boolean    @default(false)

  // M5.6 — Agradecimentos
  giftReceived        String?
  thankYouNote        String?
  thankYouSent        Boolean    @default(false)

  event               Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photos              Photo[]
  chatMessages        ChatMessage[]
  playlistSuggestions PlaylistSuggestion[]
  playlistVotes       PlaylistVote[]
  coupleMessages      CoupleMessage[]
  pointEvents         PointEvent[]
  donations           Donation[]
  checkins            Checkin[]
  giftReservations    Gift[]
  guestPoints         GuestPoints?
  reportsMade         Report[]             @relation("Reporter")
  companions          GuestCompanion[]

  @@unique([eventId, email])
  @@index([eventId, sessionToken])
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum CompanionType {
  ADULT
  CHILD
}

model GuestCompanion {
  id        String        @id @default(cuid())
  guestId   String
  name      String
  type      CompanionType @default(ADULT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

model EventLocation {
  id            String       @id @default(cuid())
  eventId       String
  type          LocationType
  title         String
  address       String?
  date          DateTime?
  timeLabel     String?
  dresscode     String?
  description   String?      @db.Text
  coverImageKey String?
  isMain        Boolean      @default(false)
  order         Int          @default(0)
  isPublic      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
  @@index([eventId, type, isMain])
}

model JourneyItem {
  id          String  @id @default(cuid())
  eventId     String
  time        String
  title       String
  description String?
  icon        String?
  location    String?
  order       Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Gift {
  id                String    @id @default(cuid())
  eventId           String
  name              String
  description       String?
  price             Float?
  imageKey          String?
  externalLink      String?
  reservedByGuestId String?
  reservedAt        DateTime?
  fulfilled         Boolean   @default(false)

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reserver  Guest?     @relation(fields: [reservedByGuestId], references: [id])
  donations Donation[]
}

model Photo {
  id               String          @id @default(cuid())
  eventId          String
  guestId          String
  storageKey       String
  caption          String?
  visibility       PhotoVisibility @default(PUBLIC)
  approvedByCouple Boolean         @default(true)
  removedAt        DateTime?
  createdAt        DateTime        @default(now())

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest     Guest           @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reports   Report[]
  reactions PhotoReaction[]
}

enum PhotoVisibility {
  PUBLIC
  COUPLE_ONLY
}

model PhotoReaction {
  id        String   @id @default(cuid())
  photoId   String
  emoji     String
  guestId   String?
  sessionId String?
  createdAt DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, sessionId, emoji])
  @@index([photoId])
}

model ChatMessage {
  id        String    @id @default(cuid())
  eventId   String
  guestId   String
  content   String    @db.Text
  reactions Json      @default("{}")
  removedAt DateTime?
  createdAt DateTime  @default(now())

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest   Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reports Report[]
}

model PlaylistSuggestion {
  id              String               @id @default(cuid())
  eventId         String
  guestId         String
  trackName       String
  artist          String
  externalLink    String?
  spotifyTrackId  String?
  previewUrl      String?
  albumArtUrl     String?
  approved        Boolean              @default(true)
  songStatus      PlaylistSongStatus   @default(PENDING)
  createdAt       DateTime             @default(now())

  event Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  votes PlaylistVote[]

  @@index([eventId, songStatus])
}

enum PlaylistSongStatus {
  PENDING
  APPROVED
  REJECTED
  PLAYED
}

model PlaylistVote {
  suggestionId String
  guestId      String
  createdAt    DateTime @default(now())

  suggestion PlaylistSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  guest      Guest              @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([suggestionId, guestId])
}

model CoupleMessage {
  id        String   @id @default(cuid())
  eventId   String
  guestId   String
  content   String   @db.Text
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

// --- Gamificação ---

model Mission {
  id          String  @id @default(cuid())
  eventId     String
  code        String
  title       String
  description String?
  points      Int
  dailyCap    Int?
  totalCap    Int?
  config      Json?
  active      Boolean @default(true)
  order       Int

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pointEvents  PointEvent[]
  checkinCodes CheckinCode[]

  @@unique([eventId, code])
}

model GuestPoints {
  guestId     String   @id
  eventId     String
  totalPoints Int      @default(0)
  lastUpdated DateTime @default(now())

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model PointEvent {
  id          String   @id @default(cuid())
  guestId     String
  eventId     String
  missionId   String?
  points      Int
  reason      String
  metadata    Json?
  provisional Boolean  @default(false)
  createdAt   DateTime @default(now())

  guest   Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mission Mission? @relation(fields: [missionId], references: [id])

  @@index([guestId, createdAt])
  @@index([eventId, createdAt])
}

// --- Doações ---

model Donation {
  id               String         @id @default(cuid())
  eventId          String
  guestId          String
  giftId           String?
  amount           Float
  mode             DonationMode
  status           DonationStatus @default(DECLARED)
  proofImageKey    String?
  gatewayProvider  String?
  gatewayPaymentId String?
  approvedAt       DateTime?
  approvedByUserId String?
  rejectedReason   String?
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  gift  Gift?  @relation(fields: [giftId], references: [id], onDelete: SetNull)

  @@index([eventId, status])
  @@index([gatewayPaymentId])
}

enum DonationStatus {
  DECLARED
  PROOF_UPLOADED
  APPROVED
  REJECTED
  PAID
}

// --- Check-in ---

model CheckinCode {
  id         String    @id @default(cuid())
  eventId    String
  code       String
  purpose    String
  missionId  String?
  validFrom  DateTime?
  validUntil DateTime?
  active     Boolean   @default(true)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mission  Mission?  @relation(fields: [missionId], references: [id])
  checkins Checkin[]

  @@unique([eventId, code])
}

model Checkin {
  id          String   @id @default(cuid())
  eventId     String
  guestId     String
  codeId      String
  checkedInAt DateTime @default(now())
  lat         Float?
  lng         Float?

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  code  CheckinCode @relation(fields: [codeId], references: [id])
}

// --- Moderação ---

model Report {
  id              String       @id @default(cuid())
  eventId         String
  reporterGuestId String
  targetType      ReportTarget
  photoId         String?
  chatMessageId   String?
  reason          String?
  status          ReportStatus @default(PENDING)
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reporter    Guest        @relation("Reporter", fields: [reporterGuestId], references: [id])
  photo       Photo?       @relation(fields: [photoId], references: [id])
  chatMessage ChatMessage? @relation(fields: [chatMessageId], references: [id])
}

enum ReportTarget {
  PHOTO
  MESSAGE
}

enum ReportStatus {
  PENDING
  REVIEWED
  REMOVED
  DISMISSED
}

// --- LGPD logs ---

model DataAccessLog {
  id        String   @id @default(cuid())
  userId    String?
  eventId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

// --- Galeria do casal (fotos pré-evento) ---

model GalleryPhoto {
  id         String   @id @default(cuid())
  eventId    String
  storageKey String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

// --- Festa: padrinhos e madrinhas ---

model WeddingPartyMember {
  id        String      @id @default(cuid())
  eventId   String
  name      String
  role      WeddingRole @default(GROOMSMAN)
  bio       String?
  photoKey  String?
  side      WeddingSide @default(GROOM)
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, side, order])
}

enum WeddingRole {
  BEST_MAN
  MAID_OF_HONOR
  GROOMSMAN
  BRIDESMAID
  FLOWER_GIRL
  RING_BEARER
  OTHER
}

enum WeddingSide {
  BRIDE
  GROOM
}

// --- História do casal (timeline) ---

model CoupleStoryItem {
  id          String    @id @default(cuid())
  eventId     String
  date        DateTime?
  dateLabel   String?
  title       String
  description String?   @db.Text
  photoKey    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

// --- M5.2 — Sistema de mesas ---

model SeatingTable {
  id          String              @id @default(cuid())
  eventId     String
  name        String
  capacity    Int                 @default(8)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())

  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments SeatingAssignment[]

  @@index([eventId, order])
}

model SeatingAssignment {
  id        String   @id @default(cuid())
  tableId   String
  guestId   String   @unique

  table     SeatingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
}

// --- M5.4 — Live events ---

model LiveEvent {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  type      String   @default("update")
  title     String
  body      String?  @db.Text
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

// --- M5.Z — QA Dashboard ---

model QATestRun {
  id          String    @id @default(cuid())
  title       String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  results     Json      @default("{}")
  notes       String    @default("") @db.Text
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById, startedAt])
}

// --- Sala 3D Voxel (Mapa do Salão) ---

enum Venue3DObjectKind {
  TABLE_ROUND_6
  TABLE_ROUND_8
  TABLE_ROUND_10
  TABLE_ROUND_12
  TABLE_RECT_4
  TABLE_RECT_6
  TABLE_IMPERIAL_16
  TABLE_U
  TABLE_C
  TABLE_T
  BUFFET
  CAKE_TABLE
  STAGE
  DJ_BOOTH
  DANCE_FLOOR
  BAR
  PLANT
  CHANDELIER
  RUG
  FLOWER_ARCH
}

enum AvatarSource {
  PHOTO_AI
  MANUAL
}

model Venue3D {
  id             String          @id @default(cuid())
  eventId        String          @unique
  floorWidthTiles Int            @default(20)
  floorDepthTiles Int            @default(20)
  floorColor     String          @default("#F5F0E8")
  wallColor      String          @default("#E8E0D0")
  ambientLight   Float           @default(0.6)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  event   Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  objects Venue3DObject[]
  avatars Venue3DAvatar[]
}

model Venue3DObject {
  id          String            @id @default(cuid())
  venueId     String
  kind        Venue3DObjectKind
  voxModelKey String?
  posX        Float             @default(0)
  posZ        Float             @default(0)
  rotation    Float             @default(0)
  number      Int?
  label       String?
  seats       Int?
  guests      Json              @default("[]")
  createdAt   DateTime          @default(now())

  venue   Venue3D         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  avatars Venue3DAvatar[]

  @@index([venueId])
}

model Venue3DAvatar {
  id                String       @id @default(cuid())
  venueId           String
  guestId           String       @unique
  source            AvatarSource @default(MANUAL)
  skinTone          String       @default("#FDBCB4")
  hairColor         String       @default("#3B2314")
  hairStyle         String       @default("short")
  shirtColor        String       @default("#4A90D9")
  pantsColor        String       @default("#2C3E50")
  hasGlasses        Boolean      @default(false)
  hasBeard          Boolean      @default(false)
  assignedSeatIndex Int?
  assignedObjectId  String?
  currentX          Float        @default(0)
  currentZ          Float        @default(0)
  facing            String       @default("south")
  isWalking         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  venue          Venue3D        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  assignedObject Venue3DObject? @relation(fields: [assignedObjectId], references: [id])

  @@index([venueId])
}
