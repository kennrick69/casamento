# Banco de dados (Railway Postgres — copie a URL do painel Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Auth.js
AUTH_SECRET="gere com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Resend (email transacional)
# Deixe em branco em dev — emails serão logados no console
RESEND_API_KEY=""
EMAIL_FROM="Casamento <noreply@seudominio.com.br>"

# Pusher (realtime do chat)
# Deixe em branco em dev — realtime será simulado no console
PUSHER_APP_ID=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""

# Storage (Railway Volume — montado em /data/uploads no Railway)
# Em dev usa /tmp/casamento-uploads automaticamente
STORAGE_PATH="/data/uploads"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
