# =============================================================================
# BANCO DE DADOS
# =============================================================================

# URL de conexão do Postgres (Railway: Settings → Database → Connection URL)
DATABASE_URL=""

# =============================================================================
# AUTENTICAÇÃO (Auth.js v5 / NextAuth)
# =============================================================================

# Chave secreta do Auth.js. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL pública do app (sem barra final).
# Em dev: http://localhost:3000
# Em prod: https://seu-projeto.up.railway.app (ou domínio próprio)
NEXTAUTH_URL=""

# Obrigatório no Railway para Auth.js confiar nos headers do proxy reverso.
# Em dev: deixe vazio. Em prod: defina como "true".
AUTH_TRUST_HOST=""

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Chave de API do Resend (resend.com → API Keys).
# Deixe vazio em dev — emails serão logados no console.
RESEND_API_KEY=""

# Remetente dos emails transacionais. Formato: "Nome <email@seudominio.com.br>"
# O domínio deve estar verificado no Resend com SPF/DKIM/DMARC.
EMAIL_FROM=""

# =============================================================================
# REALTIME (Pusher)
# =============================================================================

# Credenciais do Pusher (dashboard.pusher.com → App Keys).
# Deixe vazio em dev — realtime será simulado no console.
PUSHER_APP_ID=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Chave pública do Pusher — usada no servidor (sem expor no bundle do front).
# Mesmo valor que NEXT_PUBLIC_PUSHER_KEY.
PUSHER_KEY=""

# Chave pública do Pusher — usada no cliente (browser).
NEXT_PUBLIC_PUSHER_KEY=""

# =============================================================================
# STORAGE
# =============================================================================

# Provedor de storage. Valores possíveis:
#   "railway" (default) — volume persistente do Railway em RAILWAY_VOLUME_PATH
#   "r2"                — Cloudflare R2 (implementar quando atingir gatilho em tech-debt.md)
STORAGE_PROVIDER=""

# Caminho do volume persistente do Railway (apenas quando STORAGE_PROVIDER=railway).
# Em prod (Railway): /data/uploads
# Em dev: deixe vazio — o app usa /tmp/casamento-uploads automaticamente.
RAILWAY_VOLUME_PATH=""

# =============================================================================
# APP
# =============================================================================

# URL pública do app — usada em links de email, QR codes etc.
# Em dev: http://localhost:3000
# Em prod: https://seu-projeto.up.railway.app
NEXT_PUBLIC_APP_URL=""

# Secret para autenticar chamadas ao endpoint de cron (/api/cron/backup).
# Gere com: openssl rand -hex 32
# No Railway Cron: adicione como header x-cron-secret na chamada.
CRON_SECRET=""
