# =============================================================================
# BANCO DE DADOS
# =============================================================================

# URL de conexão do Postgres (Railway: Settings → Database → Connection URL)
DATABASE_URL=""

# =============================================================================
# AUTENTICAÇÃO (Auth.js v5 / NextAuth)
# =============================================================================

# Chave secreta do Auth.js. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL pública do app (sem barra final).
# Em dev: http://localhost:3000
# Em prod: https://seu-projeto.up.railway.app (ou domínio próprio)
NEXTAUTH_URL=""

# Obrigatório no Railway para Auth.js confiar nos headers do proxy reverso.
# Em dev: deixe vazio. Em prod: defina como "true".
AUTH_TRUST_HOST=""

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Chave de API do Resend (resend.com → API Keys).
# Deixe vazio em dev — emails serão logados no console.
RESEND_API_KEY=""

# Remetente dos emails transacionais. Formato: "Nome <email@seudominio.com.br>"
# O domínio deve estar verificado no Resend com SPF/DKIM/DMARC.
EMAIL_FROM=""

# =============================================================================
# REALTIME (Pusher)
# =============================================================================

# Credenciais do Pusher (dashboard.pusher.com → App Keys).
# Deixe vazio em dev — realtime será simulado no console.
PUSHER_APP_ID=""
PUSHER_SECRET=""

# Chave pública do Pusher — usada no servidor (não entra no bundle do front).
# Mesmo valor que NEXT_PUBLIC_PUSHER_KEY.
PUSHER_KEY=""

# Chave e cluster públicos — usados no cliente (browser) e no servidor.
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# =============================================================================
# STORAGE
# =============================================================================

# STORAGE_PROVIDER: hoje sempre usa "railway" hardcoded. Esta var
# será efetivamente lida quando a migração pra Cloudflare R2
# acontecer (ver docs/tech-debt.md). Mantida aqui pra não esquecer
# de configurar no momento da migração.
STORAGE_PROVIDER=railway

# Caminho do volume persistente do Railway (apenas quando STORAGE_PROVIDER=railway).
# Em prod (Railway): /data/uploads
# Em dev: deixe vazio — o app usa /tmp/casamento-uploads automaticamente.
RAILWAY_VOLUME_PATH=""

# =============================================================================
# APP
# =============================================================================

# URL pública do app — usada em links de email, QR codes etc.
# Em dev: http://localhost:3000
# Em prod: https://seu-projeto.up.railway.app
NEXT_PUBLIC_APP_URL=""

# Secret para autenticar chamadas ao endpoint de cron (/api/cron/backup).
# Gere com: openssl rand -hex 32
# No Railway Cron: adicione como header x-cron-secret na chamada.
CRON_SECRET=""

# =============================================================================
# CAPTCHA (Cloudflare Turnstile)
# =============================================================================

# Crie em: dash.cloudflare.com → Turnstile → Add site
# Em dev: deixe vazio — verificação é pulada automaticamente.
# Chaves de teste oficiais:
#   always-pass → site: 1x00000000000000000000AA  /  secret: 1x0000000000000000000000000000000AA
#   always-fail → site: 2x00000000000000000000AB  /  secret: 2x0000000000000000000000000000000AB
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# =============================================================================
# CRIPTOGRAFIA (obrigatória para Mercado Pago)
# =============================================================================

# Chave AES-256 para criptografar credentials de pagamento no banco.
# Gere com: openssl rand -hex 32
# OBRIGATÓRIA se qualquer evento usar o modo Mercado Pago.
# Sem ela, o botão "Salvar" do Mercado Pago retorna erro.
ENCRYPTION_KEY=""

# =============================================================================
# SPOTIFY (playlist de músicas — opcional)
# =============================================================================

# Crie em: developers.spotify.com → Create app → Client ID + Secret
# Sem essas variáveis, a busca de músicas fica desabilitada.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# =============================================================================
# BACKBLAZE B2 (backup off-site — opcional)
# =============================================================================

# Se configurado, backups diários também são enviados para B2.
# Sem as variáveis, apenas backups locais (Railway volume) são feitos.
B2_KEY_ID=""
B2_APPLICATION_KEY=""
B2_BUCKET=""
B2_ENDPOINT=""

# =============================================================================
# SENTRY (monitoramento de erros em produção)
# =============================================================================

# Crie em: sentry.io → Settings → Projects → Client Keys (DSN)
# Plano grátis: 5k events/mês — suficiente pra MVP.
# Se não configurado, Sentry fica desativado (graceful no-op).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Opcionais — necessários apenas para upload de source maps via CLI Sentry
SENTRY_ORG=""
SENTRY_PROJECT=""
